# Polaris runtime mode
POLARIS_ENV=development
POLARIS_DEBUG=1
POLARIS_ALLOWED_ORIGINS=*

# Auth
POLARIS_JWT_SECRET=replace-with-a-long-random-secret
POLARIS_ACCESS_TOKEN_EXPIRE_MINUTES=60
POLARIS_AUTH_USERNAME=authority-admin
POLARIS_AUTH_PASSWORD=replace-with-a-strong-password
POLARIS_INGEST_USERNAME=camera-ingest
POLARIS_INGEST_PASSWORD=replace-with-a-strong-password

# Database
MONGO_URL=mongodb://localhost:27017

# Upload / endpoint hardening
POLARIS_MAX_UPLOAD_BYTES=5242880
POLARIS_ENABLE_DEBUG_ENDPOINTS=1
POLARIS_ENABLE_TEST_ALERT_ENDPOINTS=1

# Polaris local
POLARIS_BASE_URL=http://127.0.0.1:8000

# Valkey
VALKEY_HOST=localhost
VALKEY_PORT=6379
POLARIS_VALKEY_CHANNEL=polaris:decisions

# Firebase Cloud Messaging (FCM)
FCM_PROJECT_ID=your-firebase-project-id
FCM_SERVICE_ACCOUNT_FILE=relative/or/absolute/path/to/firebase-adminsdk.json
FCM_SERVICE_ACCOUNT_JSON=
FCM_DEVICE_TOKENS=
FCM_TOPIC=
FCM_INCLUDE_ENV_TOKENS=0
ALERT_DEDUP_SECONDS=180
ALERT_RETRY_ENABLED=1
ALERT_RETRY_INTERVAL_SECONDS=30
ALERT_RETRY_MAX_ATTEMPTS=3
ALERT_RETRY_BATCH_SIZE=20

# Deployment
WEBSITES_PORT=8000
